# ===== App Security =====
# Set a password to protect access (leave blank to disable auth)
APP_PASSWORD=your_password_here
# Secret key for signing auth tokens (auto-generated if not set, but set one for persistent sessions across restarts)
SECRET_KEY=your_random_secret_here

# ===== LLM API配置 =====
# Supports any OpenAI-compatible API (OpenRouter, DeepSeek, OpenAI, etc.)
# Note: simulations are token-heavy — start with <40 rounds to gauge cost

# --- Option A: OpenRouter (recommended — access 200+ models via one key) ---
# Get your key at https://openrouter.ai/keys
LLM_API_KEY=your_openrouter_api_key_here
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL_NAME=deepseek/deepseek-chat-v3-0324

# --- Option B: DeepSeek direct (cheapest single-provider option) ---
# LLM_API_KEY=your_deepseek_api_key_here
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL_NAME=deepseek-chat

# --- Option C: OpenAI direct ---
# LLM_API_KEY=your_openai_api_key_here
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL_NAME=gpt-4o-mini

# OpenRouter extra headers (optional, helps with rate-limit priority)
LLM_REFERER=https://github.com/naramalhasaniWork/MiroFish
LLM_TITLE=MiroFish

# ===== ZEP记忆图谱配置 =====
# Free tier works: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== 加速 LLM 配置（可选）=====
# Use a second LLM provider for parallel platform simulations
# Leave these out entirely if not using boost config
# LLM_BOOST_API_KEY=your_api_key_here
# LLM_BOOST_BASE_URL=your_base_url_here
# LLM_BOOST_MODEL_NAME=your_model_name_here